# Sonja HQ — test environment (RLS integration suite).
#
# Copy to `.env.test` (gitignored) to run the RLS suite locally:
#     cp .env.test.example .env.test
#     npm run supabase:start      # boot local ephemeral Supabase (Docker)
#     npm run db:reset            # replay all migrations onto the empty DB
#     npm run test:rls            # run the RLS integration suites
#
# The values below are the Supabase CLI's STANDARD local-stack defaults (the
# JWT secret is the shared local-dev demo secret), so they are safe to commit.
# They ONLY work against a local `supabase start` — NEVER point this at a real
# project: the suite creates and deletes test orgs + auth users.
#
# If your local stack uses non-default ports/keys, regenerate with:
#     supabase status -o env
SUPABASE_TEST_URL=http://127.0.0.1:54321
SUPABASE_TEST_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_TEST_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
